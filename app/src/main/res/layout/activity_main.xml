<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1E1E1E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1E1E1E"
            app:titleTextColor="#FFFFFF"
            app:popupTheme="@style/ThemeOverlay.AppCompat.Dark" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="#252526"
            android:padding="6dp">
            <TextView
                android:id="@+id/tvFilePath"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="No file open"
                android:textColor="#8C8C8C"
                android:textSize="12sp"
                android:maxLines="1"
                android:ellipsize="end" />
            <TextView
                android:id="@+id/tvSaveStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saved"
                android:textColor="#4CAF50"
                android:textSize="12sp"
                android:layout_marginStart="8dp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/tabRecyclerView"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:background="#252526"
            android:scrollbars="none" />

        <LinearLayout
            android:id="@+id/searchBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2D2D2D"
            android:padding="8dp"
            android:visibility="gone">
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">
                <EditText
                    android:id="@+id/etFind"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="ค้นหาคำ..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#707070"
                    android:textSize="14sp" />
                <Button
                    android:id="@+id/btnNext"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ถัดไป"
                    android:textSize="12sp" />
            </LinearLayout>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">
                <EditText
                    android:id="@+id/etReplace"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="แทนที่ด้วย..."
                    android:textColor="#FFFFFF"
                    android:textColorHint="#707070"
                    android:textSize="14sp" />
                <Button
                    android:id="@+id/btnReplace"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="แทนที่"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1E1E1E">

            <LinearLayout
                android:id="@+id/emptyStateView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">
                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="#CCCCCC" />
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">
                        <View
                            android:layout_width="70dp"
                            android:layout_height="12dp"
                            android:background="#CCCCCC" />
                        <View
                            android:layout_width="140dp"
                            android:layout_height="12dp"
                            android:background="#CCCCCC"
                            android:layout_marginTop="10dp" />
                        <View
                            android:layout_width="45dp"
                            android:layout_height="12dp"
                            android:background="#CCCCCC"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="16dp">
                    <View
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@android:drawable/presence_online"
                        android:backgroundTint="#CCCCCC" />
                    <LinearLayout
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="20dp">
                        <View
                            android:layout_width="125dp"
                            android:layout_height="12dp"
                            android:background="#CCCCCC" />
                        <View
                            android:layout_width="175dp"
                            android:layout_height="12dp"
                            android:background="#CCCCCC"
                            android:layout_marginTop="10dp" />
                        <View
                            android:layout_width="40dp"
                            android:layout_height="12dp"
                            android:background="#CCCCCC"
                            android:layout_marginTop="10dp" />
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Don't open files"
                    android:textColor="#8C8C8C"
                    android:textSize="18sp"
                    android:layout_marginTop="35dp" />
            </LinearLayout>

            <io.github.rosemoe.sora.widget.CodeEditor
                android:id="@+id/codeEditor"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:visibility="gone" /> 
                
            <FrameLayout
                android:id="@+id/previewContainer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#1E1E1E"
                android:visibility="gone" />
        </FrameLayout>

        <LinearLayout
            android:id="@+id/aiSuggestionBar"
            android:layout_width="match_parent"
            android:layout_height="38dp"
            android:background="#2D203D"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:visibility="gone">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ AI แนะนำ: "
                android:textColor="#BB86FC"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAiSuggestionText"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="..."
                android:textColor="#A5A5A5"
                android:textSize="12sp"
                android:fontFamily="monospace" />

            <Button
                android:id="@+id/btnAcceptAiSuggestion"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:backgroundTint="#BB86FC"
                android:text="แทรกโค้ด"
                android:textColor="#121212"
                android:textSize="10sp"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton" />
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#202020"
            android:scrollbars="none">
            <LinearLayout
                android:id="@+id/shortcutBar"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:orientation="horizontal"
                android:paddingStart="4dp"
                android:paddingEnd="4dp"
                android:gravity="center_vertical" />
        </HorizontalScrollView>

        <LinearLayout
            android:id="@+id/consolePanel"
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:orientation="vertical"
            android:background="#1E1E1E"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:orientation="horizontal"
                android:background="#2D2D2D"
                android:gravity="center_vertical"
                android:paddingStart="8dp"
                android:paddingEnd="8dp">
                
                <com.google.android.material.tabs.TabLayout
                    android:id="@+id/consoleFilterTabs"
                    android:layout_width="160dp"
                    android:layout_height="match_parent"
                    android:background="#2D2D2D"
                    app:tabTextColor="#8C8C8C"
                    app:tabSelectedTextColor="#FFFFFF"
                    app:tabIndicatorColor="#BB86FC"
                    app:tabIndicatorHeight="2dp"
                    app:tabMode="fixed" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <ImageButton
                    android:id="@+id/btnConsoleScrollDown"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/arrow_down_float"
                    app:tint="#FFFFFF" />
                
                <ImageButton
                    android:id="@+id/btnConsoleClear"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    app:tint="#FFFFFF" />
                
                <ImageButton
                    android:id="@+id/btnToggleExpand"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_compass"
                    app:tint="#FFB74D" />
                <ImageButton
                    android:id="@+id/btnCloseConsole"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_delete"
                    app:tint="#FF5252" />
            </LinearLayout>

            <androidx.viewpager2.widget.ViewPager2
                android:id="@+id/viewPager"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <ScrollView
                android:id="@+id/consoleScrollView"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone">
                <View
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </ScrollView>

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvErrorPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#2D1F1F"
            android:visibility="gone" />

    </LinearLayout>

    <com.google.android.material.navigation.NavigationView
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#252526">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:padding="8dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="โครงสร้างโปรเจกต์"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:padding="8dp" />
            <ListView
                android:id="@+id/treeView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:divider="@null" />
        </LinearLayout>
    </com.google.android.material.navigation.NavigationView>

</androidx.drawerlayout.widget.DrawerLayout>